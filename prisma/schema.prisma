generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserWebsite {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  posts Post[]
}

model Post {
  id        Int          @id @default(autoincrement())
  content   String?
  published Boolean?     @default(false)
  author    UserWebsite? @relation(fields: [authorId], references: [id])
  authorId  Int?
}